---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { siteConfig } from "../../data/site";
import { toAbsoluteUrl } from "../../lib/seo";

const photos = (await getCollection("photos")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Photos",
  url: `${siteConfig.siteUrl}/photos/`,
  description:
    "A small gallery of the images I actually want to keep around, with each photo shown in its natural proportions.",
  image: toAbsoluteUrl(siteConfig.defaultSocialImage),
};
---

<SiteLayout
  title="Photos | Dylan H"
  description="A small gallery of the images I actually want to keep around, with each photo shown in its natural proportions."
  ogImage={siteConfig.defaultSocialImage}
  ogImageAlt={siteConfig.defaultSocialImageAlt}
  structuredData={structuredData}
>
  <section class="listing-hero">
    <p class="eyebrow">Photography</p>
    <h1>Photos</h1>
    <p class="hero-text">A small gallery of the images I actually want to keep around, with each photo shown in its natural proportions.</p>
  </section>

  <section class="photo-gallery">
    {photos.map((photo) => (
      <figure class="gallery-item">
        <a href={`/photos/${photo.id}/`} class="gallery-link">
          <img src={photo.data.image} alt={photo.data.alt} loading="lazy" />
          <span class="gallery-overlay">
            <strong>{photo.data.title}</strong>
            <span>{photo.data.caption}</span>
            {photo.data.location && <span class="gallery-overlay-meta">{photo.data.location}</span>}
          </span>
        </a>
      </figure>
    ))}
  </section>
</SiteLayout>
