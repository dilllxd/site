---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteConfig } from "../data/site";
import { toAbsoluteUrl } from "../lib/seo";

const [posts, photos] = await Promise.all([
  getCollection("posts"),
  getCollection("photos"),
]);

const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPosts = sortedPosts.slice(0, 3);
const sortedPhotos = photos.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPhoto = sortedPhotos[0];
const photoRotationPayload = JSON.stringify(
  sortedPhotos.map((photo) => ({
    id: photo.id,
    title: photo.data.title,
    date: photo.data.date.toISOString(),
    image: photo.data.image,
    alt: photo.data.alt,
    caption: photo.data.caption,
  })),
);

const widgetConfig = JSON.stringify(siteConfig.widgetConfig);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteConfig.title,
    url: siteConfig.siteUrl,
    email: siteConfig.email,
    homeLocation: {
      "@type": "Place",
      name: siteConfig.location,
    },
    sameAs: siteConfig.socialLinks.map((link) => link.href),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.siteName,
    url: siteConfig.siteUrl,
    description: siteConfig.description,
    image: toAbsoluteUrl(siteConfig.defaultSocialImage),
  },
];
---

<SiteLayout structuredData={structuredData}>
  <section class="intro" aria-labelledby="intro-title">
    <div class="intro-copy">
      <p class="eyebrow">Hello from South Carolina <span aria-hidden="true">●</span></p>
      <h1 id="intro-title">I make things for <span>screens</span> & servers.</h1>
      <p class="intro-text">CS student, hobbyist developer, infrastructure tinkerer, and occasional astrophotographer. This is my small, live corner of the web.</p>
      <div class="intro-actions">
        <a class="button button-primary" href="/posts/">Open notes <span>↗</span></a>
        <a class="button button-quiet" href={`mailto:${siteConfig.email}`}>Say hello <span>↗</span></a>
      </div>
    </div>
    <div class="intro-portrait" aria-label="A photo of Dylan">
      <div class="portrait-topbar"><span>ME.JPG</span><span>×</span></div>
      <img
        class="intro-mark"
        src="/apple-touch-icon.png"
        alt="Dylan H site mark"
        width="120"
        height="120"
        loading="eager"
      />
      <div class="portrait-caption"><span>DLN_001</span><span>2026</span></div>
    </div>
  </section>

  <section class="links-line" aria-label="Social links">
    <span class="links-label">Elsewhere online →</span>
    {siteConfig.socialLinks.map((link) => (
      <a href={link.href} target="_blank" rel="noreferrer">
        {link.label}
      </a>
    ))}
  </section>

  <section class="home-status" data-widget-config={widgetConfig}>
    <div class="status-intro">
      <div>
        <p class="eyebrow"><span class="pulse-dot"></span> Live signals</p>
        <h2>What’s happening<br />right now.</h2>
      </div>
      <span class="status-code">SYS / 04</span>
    </div>
    <div class="utility-strip">
      <div class="utility-item">
        <span>01 / Location</span>
        <strong>{siteConfig.location}</strong>
      </div>
      <div class="utility-item">
        <span>02 / Local time</span>
        <strong data-local-time>Loading...</strong>
      </div>
      <div class="utility-item" data-work-chip>
        <span data-work-label>03 / Schedule</span>
        <strong data-work-status>Checking...</strong>
      </div>
    </div>
    <div class="live-cluster" data-now-row>
      <div class="live-cluster-items">
        <div class="status-chip" data-discord-chip>
          <span>04 / Discord</span>
          <strong data-discord-status>Connecting...</strong>
        </div>
        <div class="status-chip status-chip-wide" data-spotify-chip>
          <span>05 / Listening</span>
          <strong data-spotify-status>Waiting for presence data...</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="home-grid">
    <div class="section-heading">
      <div>
        <p>From the notebook</p>
        <h2>Recent transmissions</h2>
      </div>
      <a href="/posts/">See all notes ↗</a>
    </div>
    <div class="home-posts-grid">
      {latestPosts.map((post, index) => (
        <a class="post-card" href={`/posts/${post.id}/`}>
          <div class="post-card-topline">
            <span class="story-index">NOTE_{String(index + 1).padStart(2, "0")}</span>
            <span class="story-date">{post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric", timeZone: "UTC" })}</span>
          </div>
          <strong>{post.data.title}</strong>
          <p>{post.data.excerpt}</p>
          <span class="inline-meta">Read it · {post.data.readingTime} ↗</span>
        </a>
      ))}
    </div>
  </section>

  {latestPhoto && (
    <section class="photo-feature" data-photo-rotation={photoRotationPayload} data-photo-viewer data-photo-viewer-mode="overlay">
      <div class="section-heading">
        <div>
          <p>From the telescope</p>
          <h2>Captured light</h2>
        </div>
        <a href="/photos/">See all images ↗</a>
      </div>
      <a class="photo-feature-inner" href={`/photos/${latestPhoto.id}/`} data-photo-link>
        <img
          src={latestPhoto.data.image}
          alt={latestPhoto.data.alt}
          loading="lazy"
          data-photo-image
          data-photo-viewer-trigger
        />
        <div class="photo-feature-meta">
          <span class="eyebrow">Latest file / <span class="live-word">Live</span></span>
          <strong data-photo-title>{latestPhoto.data.title}</strong>
          <p data-photo-caption>{latestPhoto.data.caption}</p>
          <span class="photo-feature-cta">Inspect image <span aria-hidden="true">↗</span></span>
        </div>
      </a>
      <div class="photo-preview" aria-hidden="true" data-photo-viewer-overlay>
        <div class="photo-preview-frame">
          <div class="photo-preview-topline">
            <div class="photo-preview-meta">
              <strong data-photo-preview-title>{latestPhoto.data.title}</strong>
              <span data-photo-preview-caption>{latestPhoto.data.caption}</span>
            </div>
            <div class="photo-preview-actions">
              <button type="button" data-photo-viewer-zoom-out aria-label="Zoom out">-</button>
              <button type="button" data-photo-viewer-zoom-reset>100%</button>
              <button type="button" data-photo-viewer-zoom-in aria-label="Zoom in">+</button>
              <a
                href={`/photos/${latestPhoto.id}/`}
                data-photo-preview-link
                aria-label={`Open ${latestPhoto.data.title}`}
              >
                Open photo
              </a>
              <a
                href={latestPhoto.data.image}
                target="_blank"
                rel="noreferrer"
                data-photo-preview-full
              >
                Full size
              </a>
              <button type="button" data-photo-viewer-close aria-label="Close preview">Close</button>
            </div>
          </div>
          <div class="photo-preview-viewport" data-photo-viewer-viewport>
            <img
              src={latestPhoto.data.image}
              alt={latestPhoto.data.alt}
              loading="lazy"
              data-photo-preview-image
              data-photo-viewer-image
              draggable="false"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <script type="module" src="/scripts/live-widgets.js"></script>
  <script type="module" src="/scripts/photo-rotation.js"></script>
  <script type="module" src="/scripts/photo-viewer.js"></script>
</SiteLayout>
