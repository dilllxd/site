---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { siteConfig } from "../../data/site";
import { toAbsoluteUrl } from "../../lib/seo";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Posts",
  url: `${siteConfig.siteUrl}/posts/`,
  description: "Project write-ups, rebuilds, and the occasional longer explanation.",
  image: toAbsoluteUrl(siteConfig.defaultSocialImage),
};
---

<SiteLayout
  title="Posts | Dylan H"
  description="Project write-ups, rebuilds, and the occasional longer explanation."
  ogImageAlt={siteConfig.defaultSocialImageAlt}
  structuredData={structuredData}
>
  <section class="listing-hero">
    <div class="listing-hero-index">01</div>
    <div>
      <p class="eyebrow">Journal / Field notes</p>
      <h1>Things learned<br /><em>along the way.</em></h1>
    </div>
    <p class="hero-text">Project write-ups, rebuilds, and the occasional longer explanation — documented before I forget the interesting parts.</p>
  </section>

  <section class="listing-stack">
    {posts.map((post, index) => (
      <article class="list-entry">
        <span class="story-index">{String(index + 1).padStart(2, "0")}</span>
        <div class="list-entry-copy">
          <span class="story-date">{post.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" })} · {post.data.readingTime}</span>
          <h2><a href={`/posts/${post.id}/`}>{post.data.title}</a></h2>
          <p>{post.data.excerpt}</p>
        </div>
        <a class="entry-arrow" href={`/posts/${post.id}/`} aria-label={`Read ${post.data.title}`}>↗</a>
      </article>
    ))}
  </section>
</SiteLayout>
