---
import { siteConfig } from "../data/site";
import { stringifyStructuredData, toAbsoluteUrl } from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  hideFooter?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  publishedTime?: string;
  structuredData?: object | object[];
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  pageClass = "",
  hideFooter = false,
  ogImage = siteConfig.defaultSocialImage,
  ogImageAlt = siteConfig.defaultSocialImageAlt,
  ogType = "website",
  publishedTime,
  structuredData,
} = Astro.props;

const isHome = Astro.url.pathname === "/";
const isPosts = Astro.url.pathname.startsWith("/posts");
const isPhotos = Astro.url.pathname.startsWith("/photos");
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const socialImageUrl = toAbsoluteUrl(ogImage);
const structuredDataJson = stringifyStructuredData(structuredData);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.title} />
    <meta name="robots" content="index,follow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {publishedTime && <meta property="article:author" content={siteConfig.title} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="theme-color" content="#10120f" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson}></script>
    )}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body class={pageClass}>
    <div class={`page-shell ${pageClass}`.trim()}>
      <header class="site-header">
        <a class="brand" href="/" aria-label={`${siteConfig.title} — Home`}>
          <span class="brand-mark" aria-hidden="true">DH</span>
          <span class="brand-copy">
            <strong>{siteConfig.title}</strong>
            <span>Field notes from South Carolina</span>
          </span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          <a href="/" aria-current={isHome ? "page" : undefined}>Index</a>
          <a href="/posts/" aria-current={isPosts ? "page" : undefined}>Journal</a>
          <a href="/photos/" aria-current={isPhotos ? "page" : undefined}>Observatory</a>
        </nav>

        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle color theme">
          <span class="theme-dot" aria-hidden="true"></span>
          <span data-theme-toggle-label>Light mode</span>
        </button>
      </header>

      <main>
        <slot />
      </main>

      {!hideFooter && (
        <footer class="site-footer">
          <div class="footer-signoff">
            <span class="brand-mark" aria-hidden="true">DH</span>
            <p>Built slowly, kept personal.<br />South Carolina · {new Date().getFullYear()}</p>
          </div>
          <div class="footer-links" aria-label="Footer links">
            <a href={`mailto:${siteConfig.email}`}>Email ↗</a>
            <a href="https://github.com/dilllxd" rel="me">GitHub ↗</a>
            <a href="https://status.dylan.lol" rel="me">Systems ↗</a>
          </div>
        </footer>
      )}
    </div>
    <script type="module" src="/scripts/theme-toggle.js"></script>
  </body>
</html>
